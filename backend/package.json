{
  "name": "wwebjs-standalone-backend",
  "version": "1.0.0",
  "description": "Standalone backend for WhatsApp Web JS integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "build": "prisma generate && tsc --project tsconfig.json",
    "start": "prisma migrate deploy && node dist/index.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset"
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "whatsapp-web.js": "^1.26.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/better-sqlite3": "^7.6.13",
    "multer": "^2.1.1",
    "@types/multer": "^2.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@types/fluent-ffmpeg": "^2.1.26",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2"
  }
}
